# ── WarcraftLogs v2 API credentials ──────────────────────────────────────────
# Create an API client here:  https://www.warcraftlogs.com/api/clients/
#   - Name: anything (e.g. "guild-analyzer")
#   - Redirect URLs: http://localhost  (required field, not used by us)
#   - Leave "Public Client" UNCHECKED — we use the client-credentials flow.
# Copy the generated Client ID and Client Secret below.
WCL_CLIENT_ID=your_client_id_here
WCL_CLIENT_SECRET=your_client_secret_here

# ── Your guild ────────────────────────────────────────────────────────────────
# serverSlug is the realm name lowercased with spaces as hyphens (e.g. "argent-dawn").
# region is one of: US, EU, KR, TW, CN
GUILD_NAME=Your Guild Name
GUILD_SERVER_SLUG=your-realm-slug
GUILD_REGION=EU

# ── Optional tuning ───────────────────────────────────────────────────────────
# Default lookback window for the dashboard (days). UI can override per request.
DEFAULT_TIMEFRAME_DAYS=14
# Max reports to pull per refresh (safety cap on API usage).
MAX_REPORTS=40
# Analyze raid content only — skip Mythic+ reports (their numbers aren't comparable).
# Set to false to include Mythic+ as well.
EXCLUDE_MYTHIC_PLUS=true
